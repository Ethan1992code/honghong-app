# ============================================
# 哄哄模拟器 - 本地开发环境变量配置
# ============================================
#
# 复制此文件为 .env，然后填入你的实际值
# cp .env.example .env
#
# 注意：不要在生产环境或代码仓库中提交 .env 文件

# --------------------------------------------
# Coze SDK 认证（用于 LLM 和 TTS）
# 从扣子平台获取你的 API Key
# --------------------------------------------
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here
COZE_INTEGRATION_BASE_URL=https://api.coze.cn
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn

# --------------------------------------------
# Supabase 数据库
# 从 Supabase 项目设置中获取
# --------------------------------------------
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your_anon_key_here

# --------------------------------------------
# Iron Session（用于用户登录会话）
# 随机生成一个 32 字符以上的密钥
# 命令：openssl rand -base64 32
# --------------------------------------------
SESSION_SECRET=your_random_session_password_min_32_chars
